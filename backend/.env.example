# =============================================================================
# Rhose Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# All variables marked as REQUIRED must be set for the application to start.
#
# Quick start with Docker Compose (from project root):
#   docker compose up -d       -> starts PostgreSQL
#   npm run db:push            -> pushes schema to database
#   npm run dev                -> starts frontend + backend
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rhose

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the Express server listens on (default: 3000)
PORT=3000

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# Secret key used to sign JWT tokens (REQUIRED)
# Use a strong random string (min 32 characters recommended)
JWT_SECRET=your-jwt-secret-change-in-production

# JWT token expiration duration (default: 7d)
# Supports: '1h', '2d', '7d', '30d', etc.
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Email Service (Nodemailer over Amazon SES SMTP)
# -----------------------------------------------------------------------------
# Use the SES SMTP endpoint for your AWS region.
# Example us-east-1: email-smtp.us-east-1.amazonaws.com
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com

# SES SMTP port: 587 for STARTTLS or 465 for TLS
EMAIL_PORT=587

# SES SMTP credentials (not the same as regular AWS access keys)
EMAIL_USER=your-ses-smtp-username

EMAIL_PASS=your-ses-smtp-password

# Verified SES sender address or domain
EMAIL_FROM=noreply@rhose.com

# -----------------------------------------------------------------------------
# AWS / S3 Upload Storage
# -----------------------------------------------------------------------------
# S3 region and bucket used by all application file uploads.
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-rhose-upload-bucket

# Optional key prefix for objects inside the bucket.
S3_KEY_PREFIX=rhose

# Optional public base URL. Use this for CloudFront or a custom asset domain.
# If omitted, the app returns https://BUCKET.s3.REGION.amazonaws.com/KEY.
S3_PUBLIC_BASE_URL=

# Optional on EC2 when using an IAM instance profile/role.
# Set both only for local development or non-role based deployments.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
# Frontend application URL used for CORS origin and password reset links (REQUIRED)
FRONTEND_URL=http://localhost:5173
