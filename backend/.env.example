# =============================================================================
# Rhose Backend Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# All variables marked as REQUIRED must be set for the application to start.
#
# Quick start with Docker Compose (from project root):
#   docker compose up -d       → starts PostgreSQL + Mailpit
#   npm run db:push            → pushes schema to database
#   npm run dev                → starts frontend + backend
#
# Mailpit web UI: http://localhost:8025 (catches all outgoing emails)
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rhose

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the Express server listens on (default: 3000)
PORT=3000

# -----------------------------------------------------------------------------
# Authentication / JWT
# -----------------------------------------------------------------------------
# Secret key used to sign JWT tokens (REQUIRED)
# Use a strong random string (min 32 characters recommended)
JWT_SECRET=your-jwt-secret-change-in-production

# JWT token expiration duration (default: 7d)
# Supports: '1h', '2d', '7d', '30d', etc.
JWT_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Email Service (Nodemailer SMTP)
# -----------------------------------------------------------------------------
# For local dev with Docker Compose, use Mailpit (catches all emails):
#   EMAIL_HOST=localhost, EMAIL_PORT=1025, EMAIL_USER/PASS=anything
# SMTP host for sending emails (REQUIRED)
EMAIL_HOST=localhost

# SMTP port (Mailpit: 1025, Production: 587 for TLS, 465 for SSL)
EMAIL_PORT=1025

# SMTP authentication username (REQUIRED)
EMAIL_USER=dev@rhose.com

# SMTP authentication password (REQUIRED)
EMAIL_PASS=anything

# "From" address displayed in outgoing emails (REQUIRED)
EMAIL_FROM=noreply@rhose.com

# -----------------------------------------------------------------------------
# Frontend / CORS
# -----------------------------------------------------------------------------
# Frontend application URL used for CORS origin and password reset links (REQUIRED)
FRONTEND_URL=http://localhost:5173
